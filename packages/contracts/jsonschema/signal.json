{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optiontrader/contracts/signal.json",
  "title": "Signal",
  "description": "Deterministic trading signal produced by Python Strategy Engine.",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "signal_id": { "type": "string" },
    "session_id": { "type": "string" },
    "occurred_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "timestamp_et": { "$ref": "common.json#/$defs/etTimestamp" },
    "regime": { "type": "string", "enum": ["Trend", "Range", "Event", "Chaos", "NoTrade"] },
    "strategy": { "type": "string", "enum": ["LongGamma", "ShortPremium", "EventVolCrush", "NoTrade"] },
    "direction": { "type": "string", "enum": ["Bullish", "Bearish", "Neutral"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "initial_risk_status": {
      "type": "string",
      "enum": ["NOT_EVALUATED", "PASSED", "REJECTED"]
    },
    "reason": { "type": "array", "items": { "type": "string" } },
    "invalid_if": { "type": "array", "items": { "type": "string" } },
    "data_snapshot_ids": { "type": "array", "items": { "type": "string" } },
    "rule_version": { "type": "string" }
  },
  "required": [
    "schema_version", "signal_id", "session_id", "occurred_at_utc",
    "regime", "strategy", "initial_risk_status", "reason", "rule_version"
  ],
  "additionalProperties": false
}
