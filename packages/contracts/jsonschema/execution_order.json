{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optiontrader/contracts/execution_order.json",
  "title": "ExecutionOrder",
  "description": "Rust-authoritative execution lifecycle projection. Confirmation capability tokens are intentionally excluded.",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.1" },
    "order_id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "plan_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "broker_id": { "$ref": "common.json#/$defs/brokerId" },
    "execution_mode": { "$ref": "common.json#/$defs/executionMode" },
    "state": {
      "type": "string",
      "enum": [
        "AWAITING_CONFIRMATION", "RISK_REJECTED", "APPROVED", "SUBMITTING",
        "WORKING", "PARTIAL_FILL", "FILLED", "CANCEL_PENDING", "CANCELLED",
        "REJECTED", "EXPIRED", "RECONCILE_PENDING", "SHADOWED"
      ]
    },
    "total_quantity": { "type": "integer", "minimum": 1, "description": "Number of combo units; every candidate leg quantity is equal to this value, not summed." },
    "filled_quantity": { "type": "integer", "minimum": 0 },
    "broker_order_id": { "type": ["string", "null"] },
    "expires_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "updated_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "state_version": { "type": "integer", "minimum": 1 },
    "broker_child_order_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "broker_child_orders": {
      "type": "array",
      "items": { "$ref": "#/$defs/childOrder" }
    },
    "residual_exposure": { "type": "boolean" },
    "risk_reason_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "DATA_NOT_HEALTHY", "BROKER_NOT_HEALTHY", "BROKER_NOT_RECONCILED",
          "EVENT_CONTEXT_UNAVAILABLE", "EVENT_CONTEXT_INVALID", "EVENT_POLICY_BLOCK",
          "PLAN_EXPIRED", "PLAN_INVALID", "PLAN_HASH_MISMATCH", "SNAPSHOT_NOT_CURRENT",
          "EXECUTION_MODE_BLOCKED", "DUPLICATE_CONFLICT", "RISK_LIMITS_UNCONFIRMED",
          "KILL_SWITCH_ACTIVE", "DAILY_LOSS_LIMIT", "MAX_TRADES_REACHED",
          "LOSS_COOLDOWN_ACTIVE", "PLAN_RISK_LIMIT", "OPEN_RISK_LIMIT",
          "BUYING_POWER_INSUFFICIENT", "MAX_CONTRACTS_EXCEEDED", "RULE_VERSION_MISMATCH",
          "QUOTE_PROOF_INVALID", "QUOTE_STALE", "QUOTE_SPREAD_TOO_WIDE", "GREEKS_INVALID",
          "CHAIN_SNAPSHOT_MISMATCH", "STRATEGY_NOT_ALLOWED", "ENTRY_WINDOW_CLOSED",
          "MARKET_ORDER_BLOCKED", "POSITION_NOT_REDUCIBLE"
        ]
      }
    }
  },
  "required": [
    "schema_version", "order_id", "plan_id", "plan_hash", "idempotency_key",
    "session_id", "broker_id", "execution_mode", "state", "total_quantity",
    "filled_quantity", "broker_order_id", "expires_at_utc", "updated_at_utc", "state_version",
    "risk_reason_codes", "broker_child_order_ids", "broker_child_orders", "residual_exposure"
  ],
  "additionalProperties": false,
  "$defs": {
    "childOrder": {
      "type": "object",
      "properties": {
        "broker_order_id": { "type": "string", "minLength": 1 },
        "leg_index": { "type": "integer", "minimum": 0 },
        "contract_id": { "type": "string", "minLength": 1 },
        "side": { "type": "string", "enum": ["BUY", "SELL"] },
        "quantity": { "type": "integer", "minimum": 1 },
        "filled_quantity": { "type": "integer", "minimum": 0 },
        "state": {
          "type": "string",
          "enum": ["WORKING", "PARTIAL_FILL", "FILLED", "CANCELLED", "REJECTED", "RECONCILE_PENDING"]
        },
        "submitted_price": { "type": ["string", "null"], "pattern": "^[0-9]+(\\.[0-9]+)?$" }
      },
      "required": [
        "broker_order_id", "leg_index", "contract_id", "side", "quantity",
        "filled_quantity", "state", "submitted_price"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": { "properties": { "state": { "const": "FILLED" } }, "required": ["state"] },
          "then": { "properties": { "filled_quantity": { "minimum": 1 } } }
        },
        {
          "if": { "properties": { "state": { "const": "REJECTED" } }, "required": ["state"] },
          "then": { "properties": { "filled_quantity": { "const": 0 } } }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "residual_exposure": { "const": true } }, "required": ["residual_exposure"] },
      "then": {
        "properties": {
          "state": { "enum": ["WORKING", "PARTIAL_FILL", "RECONCILE_PENDING", "CANCEL_PENDING", "CANCELLED"] }
        }
      }
    },
    {
      "if": { "properties": { "state": { "const": "PARTIAL_FILL" } }, "required": ["state"] },
      "then": { "properties": { "residual_exposure": { "const": true } } }
    },
    {
      "if": {
        "properties": {
          "state": { "enum": ["WORKING", "RECONCILE_PENDING"] },
          "broker_child_orders": { "minItems": 1 }
        },
        "required": ["state", "broker_child_orders"]
      },
      "then": { "properties": { "residual_exposure": { "const": true } } }
    }
  ]
}
