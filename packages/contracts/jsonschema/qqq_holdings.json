{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optiontrader/contracts/qqq_holdings.json",
  "title": "QqqHoldingsDocument",
  "$defs": {
    "holding": {
      "type": "object",
      "properties": {
        "symbol": { "type": "string", "pattern": "^[A-Z][A-Z0-9.-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "weight": { "$ref": "common.json#/$defs/decimal" }
      },
      "required": ["symbol", "name", "weight"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "as_of_date": { "type": "string", "format": "date" },
    "source": { "type": "string", "minLength": 1 },
    "source_timestamp_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "received_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "raw_ref": { "type": "string", "minLength": 1 },
    "holdings": { "type": "array", "minItems": 20, "items": { "$ref": "#/$defs/holding" } }
  },
  "required": ["schema_version", "as_of_date", "source", "source_timestamp_utc", "received_at_utc", "confidence", "raw_ref", "holdings"],
  "additionalProperties": false
}
