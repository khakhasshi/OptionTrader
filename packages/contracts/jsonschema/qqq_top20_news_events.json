{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optiontrader/contracts/qqq_top20_news_events.json",
  "title": "QqqTop20NewsEventsDocument",
  "$defs": {
    "newsEvent": {
      "type": "object",
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "symbols": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9.-]*$" } },
        "headline": { "type": "string", "minLength": 1, "maxLength": 500 },
        "event_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
        "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "source": { "type": "string", "minLength": 1 },
        "source_timestamp_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
        "received_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "raw_ref": { "type": "string", "minLength": 1 }
      },
      "required": ["event_id", "symbols", "headline", "event_at_utc", "severity", "source", "source_timestamp_utc", "received_at_utc", "confidence", "raw_ref"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "source": { "type": "string", "minLength": 1 },
    "source_timestamp_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "received_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "raw_ref": { "type": "string", "minLength": 1 },
    "trading_date": { "type": "string", "format": "date" },
    "events": { "type": "array", "items": { "$ref": "#/$defs/newsEvent" } }
  },
  "required": ["schema_version", "source", "source_timestamp_utc", "received_at_utc", "confidence", "raw_ref", "trading_date", "events"],
  "additionalProperties": false
}
