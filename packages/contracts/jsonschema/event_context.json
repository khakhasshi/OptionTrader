{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optiontrader/contracts/event_context.json",
  "title": "EventContext",
  "description": "Daily event context produced by Python Event Context Layer. Authoritative record lives in PostgreSQL events schema; JSON is exchange/display only.",
  "$defs": {
    "sourceDocument": {
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["macro", "holdings", "earnings", "news"] },
        "source": { "type": "string", "minLength": 1 },
        "source_timestamp_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
        "received_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "raw_ref": { "type": "string", "minLength": 1 }
      },
      "required": ["category", "source", "source_timestamp_utc", "received_at_utc", "confidence", "raw_ref"],
      "additionalProperties": false
    }
  },
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "event_context_id": { "type": "string" },
    "trading_date": { "type": "string", "format": "date" },
    "generated_at_utc": { "$ref": "common.json#/$defs/utcTimestamp" },
    "available": { "type": "boolean" },
    "source_documents": {
      "type": "array",
      "maxItems": 4,
      "items": { "$ref": "#/$defs/sourceDocument" }
    },
    "event_day_type": {
      "type": "string",
      "enum": ["Normal", "MacroEvent", "EarningsEvent", "FOMC", "Mixed", "HighRisk"]
    },
    "macro_events": { "type": "array", "items": { "$ref": "macro_events.json#/$defs/macroEvent" } },
    "earnings_events": { "type": "array", "items": { "$ref": "qqq_top20_earnings.json#/$defs/earningsEvent" } },
    "news_events": { "type": "array", "items": { "$ref": "qqq_top20_news_events.json#/$defs/newsEvent" } },
    "qqq_weighted_event_score": { "$ref": "common.json#/$defs/decimal" },
    "minutes_to_major_event": { "type": ["integer", "null"] },
    "event_released": { "type": "boolean" },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "NO_SHORT_PREMIUM_BEFORE_EVENT",
          "SIZE_HALF",
          "WAIT_AFTER_RELEASE",
          "ELEVATED_EVENT_RISK",
          "NO_NAKED_0DTE"
        ]
      }
    },
    "deterministic_context_summary": { "type": "string" }
  },
  "required": [
    "schema_version", "event_context_id", "trading_date",
    "generated_at_utc", "available", "source_documents", "event_day_type", "macro_events",
    "earnings_events", "news_events", "qqq_weighted_event_score",
    "minutes_to_major_event", "event_released", "risk_flags",
    "deterministic_context_summary"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "available": { "const": true } }, "required": ["available"] },
      "then": { "properties": { "source_documents": { "minItems": 4, "maxItems": 4 } } }
    }
  ]
}
