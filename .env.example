# OptionTrader 环境变量模板 — 复制为 .env 并填入真实值。切勿提交真实 .env。

# --- 运行环境 (local | replay | shadow | paper | live)；live 默认关闭 ---
OPTIONTRADER_ENV=local
LIVE_TRADING_ENABLED=false

# --- PostgreSQL (唯一主数据库) ---
DATABASE_URL=postgresql://optiontrader:optiontrader@localhost:5432/optiontrader
# Fernet key for short-lived confirmation capabilities. Generate locally with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
OPTIONTRADER_CONFIRMATION_FERNET_KEY=

# --- ThetaData (Market Data Truth) ---
# 三选一；推荐凭证文件仅授予当前用户读权限 (chmod 600)
THETADATA_CREDENTIALS_FILE=
THETADATA_DOTENV_PATH=
THETADATA_API_KEY=
THETADATA_SDK_BIND=127.0.0.1:50052
THETADATA_SDK_GRPC=http://127.0.0.1:50052

# replay | theta-sdk；theta-sdk 由官方 Python SDK 直连，不要求 Theta Terminal
OPTIONTRADER_MARKET_SOURCE=replay
# gRPC 市场流持续无 tick 超过该秒数时，Application Service 主动断线重连并闭锁
OPTIONTRADER_STREAM_SILENCE_SECONDS=90

# 四类事件 JSON 根目录；按 YYYY-MM-DD 子目录组织，缺失或过期即禁开新仓
OPTIONTRADER_EVENT_DIR=../../data/events

# --- Broker: Longbridge (Event Context + 可选 Broker) ---
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
# 仅用于显式运行 ignored 的只读 demo smoke；常规测试必须保持 false。
OPTIONTRADER_RUN_LONGBRIDGE_DEMO_SMOKE=false

# --- Broker: IBKR (可选 Broker；TWS/Gateway 共用本机 sidecar) ---
OPTIONTRADER_IBKR_MODE=GATEWAY
OPTIONTRADER_IBKR_HOST=127.0.0.1
# 留空时按 TWS/Gateway + paper/live 自动选择 7497/7496/4002/4001
OPTIONTRADER_IBKR_PORT=
OPTIONTRADER_IBKR_CLIENT_ID=37
OPTIONTRADER_IBKR_ACCOUNT=
OPTIONTRADER_IBKR_PAPER=true
OPTIONTRADER_IBKR_SUBMISSION_ENABLED=false
OPTIONTRADER_IBKR_SIDECAR_BIND=127.0.0.1:50053

# 持续只读事实对账；默认仅 IBKR。启用 Longbridge 前必须配置上方三项凭证。
OPTIONTRADER_BROKER_RECONCILIATION_ENABLED=true
OPTIONTRADER_BROKER_RECONCILIATION_INTERVAL_SECONDS=30
OPTIONTRADER_BROKER_RECONCILIATION_BROKERS=ibkr

# --- Phase 3 Rust 权威风控（占位值，paper/live 前必须人工确认） ---
# 未显式改为 true 时，所有候选计划均以 RISK_LIMITS_UNCONFIRMED 拒绝。
OPTIONTRADER_RISK_LIMITS_CONFIRMED=false
OPTIONTRADER_RULE_VERSION=UNCONFIRMED
OPTIONTRADER_KILL_SWITCH=false
OPTIONTRADER_MAX_PLAN_LOSS=250
OPTIONTRADER_MAX_DAILY_LOSS=500
OPTIONTRADER_MAX_OPEN_RISK=500
OPTIONTRADER_MAX_DAILY_TRADES=3
OPTIONTRADER_MAX_CONTRACTS=2
# Phase 3 首个切片暂由启动配置注入；接入 broker snapshot 后由适配器权威刷新。
OPTIONTRADER_BUYING_POWER=0
OPTIONTRADER_DAILY_REALIZED_PNL=0
OPTIONTRADER_OPEN_RISK=0
OPTIONTRADER_DAILY_TRADE_COUNT=0
OPTIONTRADER_CONSECUTIVE_LOSSES=0
OPTIONTRADER_COOLDOWN_UNTIL_UTC=

# --- LLM (Phase 4 接入；provider 无关) ---
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# --- 服务端口 ---
API_PORT=8000
TRADING_CORE_PORT=8080
TRADING_CORE_GRPC_PORT=50051
TRADING_CORE_HTTP_BIND=127.0.0.1
TRADING_CORE_GRPC_BIND=127.0.0.1
WEB_PORT=5173
