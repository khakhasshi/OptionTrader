# OptionTrader 环境变量模板 — 复制为 .env 并填入真实值。切勿提交真实 .env。

# --- 运行环境 (local | replay | shadow | paper | live)；live 默认关闭 ---
OPTIONTRADER_ENV=local
LIVE_TRADING_ENABLED=false

# --- PostgreSQL (唯一主数据库) ---
DATABASE_URL=postgresql://optiontrader:optiontrader@localhost:5432/optiontrader

# --- ThetaData (Market Data Truth) ---
# 三选一；推荐凭证文件仅授予当前用户读权限 (chmod 600)
THETADATA_CREDENTIALS_FILE=
THETADATA_DOTENV_PATH=
THETADATA_API_KEY=
THETADATA_SDK_BIND=127.0.0.1:50052
THETADATA_SDK_GRPC=http://127.0.0.1:50052

# replay | theta-sdk；theta-sdk 由官方 Python SDK 直连，不要求 Theta Terminal
OPTIONTRADER_MARKET_SOURCE=replay
# gRPC 市场流持续无 tick 超过该秒数时，Application Service 主动断线重连并闭锁
OPTIONTRADER_STREAM_SILENCE_SECONDS=90

# 四类事件 JSON 根目录；按 YYYY-MM-DD 子目录组织，缺失或过期即禁开新仓
OPTIONTRADER_EVENT_DIR=../../data/events

# --- Broker: Longbridge (Event Context + 可选 Broker) ---
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=

# --- Broker: IBKR (可选 Broker) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# --- LLM (Phase 4 接入；provider 无关) ---
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=

# --- 服务端口 ---
API_PORT=8000
TRADING_CORE_PORT=8080
TRADING_CORE_GRPC_PORT=50051
WEB_PORT=5173
